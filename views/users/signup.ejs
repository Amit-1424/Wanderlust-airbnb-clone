<% layout("/layouts/boilerplate") %>

<div class="row mt-3">
    <h1 class="col-6 offset-3">SignUp on Wanderlust</h1>
    <div class="col-6 offset-3">
        <form action="/signup" method="POST" class="needs-validation" novalidate>
            <div class="mb-3">
                <lable for="username" class="form-label">Username</lable>
                <input
                    name="username"
                    id="username"
                    type="text"
                    class="form-control"
                    required
                />
                <div class="valid-feedback">Looks good!</div>
            </div>
            <div class="mb-3">
                <lable for="email" class="form-label">email</lable>
                <input
                    name="email"
                    id="email"
                    type="email"
                    class="form-control"
                    required
                />
            </div>
            <div class="mb-3">
                <lable for="password" class="form-label">password</lable>
                <input
                    name="password"
                    id="password"
                    type="password"
                    class="form-control"
                    required
                />
            </div>
            <button class=" btn btn-dark" >signup</button>
        </form>


         <!-- DIVIDER -->
        <div class="text-center my-3">
            <span class="text-muted">or</span>
        </div>


        <!-- GOOGLE LOGIN BUTTON -->
        <a href="/auth/google" class="google-btn">
            <img src="https://developers.google.com/identity/images/g-logo.png" alt="Google logo">
            Continue with Google
        </a>
        
    </div>
</div>

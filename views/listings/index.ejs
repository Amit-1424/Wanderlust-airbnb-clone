<% layout("/layouts/boilerplate") %>


<div class="container mt-4">

    <div class="filters-wrapper mb-4">

        <a href="/listings"
           class="filter-item <%= !activeCategory ? 'filter-active' : '' %>">
            <i class="fa-solid fa-border-all"></i>
            All
        </a>

        <a href="/listings?category=Beach"
           class="filter-item <%= activeCategory === 'Beach' ? 'filter-active' : '' %>">
            <i class="fa-solid fa-umbrella-beach"></i>
            Beach
        </a>

        <a href="/listings?category=Mountains"
           class="filter-item <%= activeCategory === 'Mountains' ? 'filter-active' : '' %>">
            <i class="fa-solid fa-mountain"></i>
            Mountains
        </a>

        <a href="/listings?category=Cities"
           class="filter-item <%= activeCategory === 'Cities' ? 'filter-active' : '' %>">
            <i class="fa-solid fa-city"></i>
            Cities
        </a>

        <a href="/listings?category=Luxury"
           class="filter-item <%= activeCategory === 'Luxury' ? 'filter-active' : '' %>">
            <i class="fa-solid fa-gem"></i>
            Luxury
        </a>

        <a href="/listings?category=Countryside"
           class="filter-item <%= activeCategory === 'Countryside' ? 'filter-active' : '' %>">
            <i class="fa-solid fa-tree"></i>
            Countryside
        </a>

        <a href="/listings?category=Unique"
           class="filter-item <%= activeCategory === 'Unique' ? 'filter-active' : '' %>">
            <i class="fa-solid fa-star"></i>
            Unique
        </a>

    </div>

    <!-- LISTINGS GRID -->
    <div class="row g-4">
        <% for (let listing of allListings){ %>
            <div class="col-lg-3 col-md-4 col-sm-6">
                <div class="card listing-card h-100">
                    
                    <div class="image-wrapper">
                        <img 
                            src="<%= listing.image?.url || '/default.jpg' %>" 
                            class="listing-img"
                            alt="listing image"
                        >
                    </div>

                    <div class="card-body p-3">
                        <h6 class="card-title mb-1 fw-semibold">
                            <%= listing.title %>
                        </h6>

                        <p class="small text-muted mb-1">
                            <%= listing.location %>, <%= listing.country %>
                        </p>

                        <p class="fw-bold mb-2">
                            &#8377 <%= listing.price.toLocaleString("en-IN") %>
                        </p>

                        <a href="/listings/<%= listing._id %>" 
                           class="stretched-link text-decoration-none"></a>
                    </div>
                </div>
            </div>
        <% } %>
    </div>

</div>